[Unit]
Description=Megaparser Backend (FastAPI + Uvicorn)
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/megaparser/backend
ExecStart=/var/www/megaparser/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5
EnvironmentFile=/var/www/megaparser/backend/.env
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
